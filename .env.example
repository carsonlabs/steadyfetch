# SteadyFetch Configuration
PORT=8200
HOST=0.0.0.0
STEADYFETCH_TRANSPORT=streamable-http

# Reliability settings
STEADYFETCH_MAX_RETRIES=3
STEADYFETCH_CIRCUIT_THRESHOLD=5
STEADYFETCH_CIRCUIT_COOLDOWN=120
STEADYFETCH_CACHE_TTL=3600
STEADYFETCH_TIMEOUT=30000

# Cache
STEADYFETCH_CACHE_DIR=/tmp/steadyfetch_cache
